# Backend env (set in Coolify or .env for local docker-compose)
PORT=3000
NODE_ENV=production
DATABASE_URL=file:/app/data/freelance.db
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=freelance
KEYCLOAK_CLIENT_ID=freelance-daigest
KEYCLOAK_JWKS_CACHE_TTL=600
OPENWEBUI_BASE_URL=http://openwebui.example.com
OPENWEBUI_API_KEY=changeme
OPENWEBUI_MODEL=llama3.1:latest
OPENWEBUI_REQUEST_TIMEOUT_MS=120000
CRON_SCHEDULE=0 6 * * *
SEARCH_TERMS=fullstack,frontend,entwickler
SCRAPER_MAX_PAGES=1
SCRAPER_DELAY_MS=1500
AUTO_GENERATE_ON_SCRAPE=false
CONTACT_EMAIL=you@example.com
LOG_LEVEL=info
AUTH_DISABLED=false
CORS_ORIGIN=http://localhost:5173

# Frontend env (build-time, must be VITE_-prefixed)
VITE_OIDC_AUTHORITY=https://keycloak.example.com/realms/freelance
VITE_OIDC_CLIENT_ID=freelance-daigest
VITE_OIDC_SCOPES=openid profile email
VITE_API_BASE_URL=/api